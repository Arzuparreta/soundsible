{
  "name": "soundsible-ui",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/sync-vendor-socket.mjs",
    "css:build": "tailwindcss -i ./css/app.css -o ./assets/tailwind-compiled.css --minify",
    "css:watch": "tailwindcss -i ./css/app.css -o ./assets/tailwind-compiled.css --watch",
    "dev": "vite",
    "build": "npm run css:build && vite build && node scripts/copy-static.mjs && node scripts/fix-dist-html.mjs",
    "preview": "vite preview"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "postcss-import": "^16.1.1",
    "socket.io-client": "^4.7.2",
    "tailwindcss": "^3.4.19",
    "vite": "^6.2.0"
  }
}
