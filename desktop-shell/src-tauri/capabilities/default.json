{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "org.soundsible.desktop",
  "description": "Soundsible consumer desktop shell capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-navigate",
    "core:webview:allow-webview-navigate",
    "core:tray:default",
    "core:menu:default",
    "core:event:default",
    "core:event:allow-emit",
    "core:event:allow-listen",
    "dialog:default",
    "opener:default",
    "shell:default",
    "global-shortcut:default"
  ]
}
